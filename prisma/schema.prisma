generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id          String     @id @default(cuid())
  name        String
  shortName   String
  district    String
  emailDomain String?
  createdAt   DateTime   @default(now())
  groups      OrgGroup[]
  resources   Resource[]
  users       User[]
}

model OrgGroup {
  id           String             @id @default(cuid())
  name         String
  bio          String?
  schoolId     String?
  teacherId    String
  createdAt    DateTime           @default(now())
  joinRequests GroupJoinRequest[]
  members      GroupMember[]
  messages     GroupMessage[]
  school       School?            @relation(fields: [schoolId], references: [id])
  teacher      User               @relation("TeacherGroups", fields: [teacherId], references: [id])
}

model User {
  id                String                   @id @default(cuid())
  username          String                   @unique
  email             String?                  @unique
  displayName       String?
  password          String
  description       String?
  isAdmin           Boolean                  @default(false)
  isTeacher         Boolean                  @default(false)
  isApproved        Boolean                  @default(false)
  rating            Int                      @default(1200)
  createdAt         DateTime                 @default(now())
  schoolId          String?
  xp                Int                      @default(0)
  posts             BlogPost[]
  comments          Comment[]
  ledTeams          ContestTeam[]            @relation("TeamLeader")
  sentInvites       ContestTeamInvite[]      @relation("SentInvites")
  receivedInvites   ContestTeamInvite[]      @relation("ReceivedInvites")
  joinRequests      ContestTeamJoinRequest[]
  teamMemberships   ContestTeamMember[]
  groupJoinRequests GroupJoinRequest[]
  groupMemberships  GroupMember[]
  sentMessages      GroupMessage[]
  messageReads      GroupMessageRead[]
  hintReveals       HintReveal[]
  taughtGroups      OrgGroup[]               @relation("TeacherGroups")
  ratingHistory     RatingHistory[]
  registrations     Registration[]
  resources         Resource[]
  submissions          Submission[]
  school               School?                  @relation(fields: [schoolId], references: [id])
  votes                Vote[]
  passwordResetTokens  PasswordResetToken[]
  badges               UserBadge[]
}

model Badge {
  id         String      @id @default(cuid())
  name       String      @unique
  textureUrl String?
  createdAt  DateTime    @default(now())
  users      UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

model GroupMember {
  groupId   String
  userId    String
  createdAt DateTime @default(now())
  group     OrgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model GroupJoinRequest {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     OrgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Theme {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registration {
  id        String    @id @default(cuid())
  userId    String
  contestId String
  createdAt DateTime  @default(now())
  startTime DateTime?
  isVirtual Boolean   @default(false)
  contest   Contest   @relation(fields: [contestId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  submissions Submission[]

  @@index([userId, contestId])
}

model Contest {
  id            String                   @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  themeSlug     String                   @default("global")
  accentColor   String?
  contestType   String                   @default("individual")
  duration      Int                      @default(120)
  teams         ContestTeam[]
  teamInvites   ContestTeamInvite[]
  joinRequests  ContestTeamJoinRequest[]
  problems      Problem[]
  ratingHistory RatingHistory[]
  registrations Registration[]
  submissions   Submission[]
}

model Problem {
  id            String       @id @default(cuid())
  contestId     String
  title         String
  statement     String
  correctAnswer String
  points        Int          @default(100)
  hint          String?
  hintReveals   HintReveal[]
  contest       Contest      @relation(fields: [contestId], references: [id])
  submissions   Submission[]
}

model HintReveal {
  userId    String
  problemId String
  createdAt DateTime @default(now())
  problem   Problem  @relation(fields: [problemId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, problemId])
}

model Submission {
  id             String        @id @default(cuid())
  userId         String
  contestId      String
  problemId      String
  registrationId String?
  answer         String
  isCorrect      Boolean
  isUpsolve      Boolean       @default(false)
  isVirtual      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  hintUsed       Boolean       @default(false)
  teamId         String?
  contest        Contest       @relation(fields: [contestId], references: [id])
  problem        Problem       @relation(fields: [problemId], references: [id])
  team           ContestTeam?  @relation(fields: [teamId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  registration   Registration? @relation(fields: [registrationId], references: [id])
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  content        String
  authorId       String
  isAnnouncement Boolean   @default(false)
  createdAt      DateTime  @default(now())
  author         User      @relation(fields: [authorId], references: [id])
  comments       Comment[]
  votes          Vote[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  post      BlogPost @relation(fields: [postId], references: [id])
}

model Vote {
  id        String   @id @default(cuid())
  type      String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model RatingHistory {
  id        String   @id @default(cuid())
  userId    String
  contestId String
  oldRating Int
  newRating Int
  change    Int
  createdAt DateTime @default(now())
  contest   Contest  @relation(fields: [contestId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Resource {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorId   String
  visibility String   @default("PUBLIC")
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id])
  school     School?  @relation(fields: [schoolId], references: [id])
}

model GroupMessage {
  id        String             @id @default(cuid())
  groupId   String
  authorId  String
  content   String
  createdAt DateTime           @default(now())
  author    User               @relation(fields: [authorId], references: [id])
  group     OrgGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reads     GroupMessageRead[]
}

model GroupMessageRead {
  messageId String
  userId    String
  readAt    DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
}

model ContestTeam {
  id           String                   @id @default(cuid())
  contestId    String
  name         String
  leaderUserId String
  maxSize      Int
  status       String                   @default("FORMING")
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  startTime    DateTime?
  contest      Contest                  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  leader       User                     @relation("TeamLeader", fields: [leaderUserId], references: [id])
  invites      ContestTeamInvite[]
  joinRequests ContestTeamJoinRequest[]
  members      ContestTeamMember[]
  submissions  Submission[]

  @@unique([contestId, name])
}

model ContestTeamMember {
  id         String      @id @default(cuid())
  teamId     String
  userId     String
  role       String      @default("member")
  relayOrder Int?
  joinedAt   DateTime    @default(now())
  team       ContestTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model ContestTeamInvite {
  id              String      @id @default(cuid())
  contestId       String
  teamId          String
  invitedUserId   String
  invitedByUserId String
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  contest         Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)
  invitedByUser   User        @relation("SentInvites", fields: [invitedByUserId], references: [id])
  invitedUser     User        @relation("ReceivedInvites", fields: [invitedUserId], references: [id])
  team            ContestTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model ContestTeamJoinRequest {
  id        String      @id @default(cuid())
  contestId String
  teamId    String
  userId    String
  status    String      @default("PENDING")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  contest   Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)
  team      ContestTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique // SHA-256 hash of the raw token sent in the email
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
